# Local Multimodal RAG Pipeline Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git - it contains sensitive API keys!

# ============================================================
# Qwen API (Vision Model - Cloud)
# ============================================================
# Get your API key from Alibaba Cloud/DashScope
# https://dashscope.console.aliyun.com/
QWEN_API_KEY=

# ============================================================
# LMStudio (Vision Model - Local)
# ============================================================
# URL of your LMStudio server (usually localhost or LAN IP)
LMSTUDIO_URL=http://localhost:1234/v1

# API key (LMStudio uses a custom format)
LMSTUDIO_API_KEY=

# ============================================================
# vLLM Embedding Service
# ============================================================
# URL of your vLLM embedding server
VLLM_API_URL=http://localhost:8001

# Model name/path as registered in vLLM
VLLM_MODEL_NAME=

# ============================================================
# OCR Service
# ============================================================
# URL of your PaddleOCR API server
OCR_API_URL=http://127.0.0.1:8002

# ============================================================
# Optional: Override paths from config.yaml
# ============================================================
# Database path (default: ./file_index.db)
# DB_PATH=/path/to/your/file_index.db

# Log directory (default: ./logs)
# LOG_DIR=/path/to/your/logs

# Jina model path (default: ~/models/jina-embeddings-v5-text-small/)
# JINA_MODEL_PATH=/path/to/your/jina-embeddings-v5-text-small/